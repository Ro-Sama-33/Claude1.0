# Supabase — te vinden in het dashboard onder Project Settings → API Keys
# Kopieer dit bestand naar .env.local en vul de waarden in.
NEXT_PUBLIC_SUPABASE_URL=https://wpvbdyrnagzojlxygjsd.supabase.co

# Publishable key (sb_publishable_...). Een legacy anon key werkt ook:
# zet die dan in NEXT_PUBLIC_SUPABASE_ANON_KEY in plaats van hieronder.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
